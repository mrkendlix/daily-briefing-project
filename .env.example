# ═══════════════════════════════════════════════
# DAILY BRIEFING — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── WHOOP OAuth ──
# Get these from https://developer.whoop.com → Dashboard → Your App
WHOOP_CLIENT_ID=your_client_id_here
WHOOP_CLIENT_SECRET=your_client_secret_here
WHOOP_REFRESH_TOKEN=your_refresh_token_here

# ── OpenWeatherMap ──
# Sign up free at https://openweathermap.org/api → One Call API 3.0
OPENWEATHER_API_KEY=your_key_here

# ── NewsAPI ──
# Sign up free at https://newsapi.org/register
NEWSAPI_KEY=your_key_here

# ── Email Delivery ──
# Gmail: use an App Password (not your regular password)
# Go to https://myaccount.google.com/apppasswords to generate one
EMAIL_SENDER=your.email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=your.email@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Location (default fallback if iPhone location unavailable) ──
DEFAULT_LAT=40.7128
DEFAULT_LON=-74.0060
DEFAULT_CITY=New York City
